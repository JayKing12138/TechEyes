# LLM 配置（必填）
LLM_PROVIDER=openai  # openai, anthropic 或其他兼容API
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1  # 可选，使用自定义endpoint
LLM_MODEL_ID=gpt-3.5-turbo

# 搜索工具（至少配置一个）
SERPAPI_API_KEY=  # 可选
TAVILY_API_KEY=your_tavily_key  # 推荐

# Redis 缓存
REDIS_URL=redis://localhost:6379

# 数据库（当前未使用，可不配置）
DATABASE_URL=postgresql://postgres:1234@localhost:5432/techeyes

# 应用配置
DEBUG=True
ENVIRONMENT=development
API_PORT=8000
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
